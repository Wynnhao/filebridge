{
  "apis": [
    {
      "name": "uploadDocument",
      "description": "上传文档到马档。支持两种方式：1）用户通过聊天框多模态上传 .md/.html/.txt 文件；2）用户粘贴文本内容（Markdown/HTML/纯文本）。上传成功后返回文档信息及分享码，他人可通过分享码查看文档。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "content": {
            "type": "string",
            "description": "文档文本内容。当用户粘贴文本而非上传文件时使用。Markdown、HTML 或纯文本。自动根据内容特征识别文件类型：首行为 '#' 或含代码块 `` ``` `` 的为 Markdown；以 '<!DOCTYPE' 或 '<html' 开头的为 HTML；其他为纯文本(TXT)"
          },
          "file": {
            "type": "object",
            "description": "用户通过聊天框上传的文件。由小程序 AI 自动注入，无需手动构造。支持 .md/.html/.htm/.txt 格式",
            "format": "file"
          },
          "filename": {
            "type": "string",
            "description": "文件名。当用户上传文件时，自动使用原文件名；当粘贴文本时，不传此参数，系统会自动生成如 '粘贴文本' 的名称"
          },
          "expiryDays": {
            "type": "integer",
            "description": "文档有效期（天）。可选值：1、3、7、30。不传默认 7 天。用户可能说'永久保存''不过期''永久的'，此时不传此参数由系统按默认值处理"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "shareCode": {
            "type": "string",
            "description": "8 位分享码，由字母和数字组成。用户可将此码发送给微信好友，好友在小程序中输入后即可查看文档"
          },
          "title": {
            "type": "string",
            "description": "文档标题，自动从内容提取"
          },
          "fileType": {
            "type": "string",
            "description": "文档类型：md/html/txt"
          },
          "wordCount": {
            "type": "integer",
            "description": "文档字数"
          },
          "expiresAt": {
            "type": "string",
            "description": "过期时间，ISO 日期格式"
          }
        }
      },
      "_meta": {
        "ui": {
          "componentPath": "components/doc-detail-card/doc-detail-card"
        }
      }
    },
    {
      "name": "searchMyDocs",
      "description": "搜索/列出当前用户已上传的文档。按创建时间倒序排列，支持按标题关键词搜索。不显示已过期文档。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "keyword": {
            "type": "string",
            "description": "搜索关键词，模糊匹配文档标题。用户说'查看所有文档''我的文档''列表'时不传；说'搜索XX''找XX文档'时传。为空或不传则返回全部文档"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "docs": {
            "type": "array",
            "description": "文档列表",
            "items": {
              "type": "object",
              "properties": {
                "docId": {
                  "type": "string",
                  "description": "文档数据库唯一 ID"
                },
                "title": {
                  "type": "string",
                  "description": "文档标题"
                },
                "fileType": {
                  "type": "string",
                  "description": "文档类型"
                },
                "wordCount": {
                  "type": "integer",
                  "description": "字数"
                },
                "viewCount": {
                  "type": "integer",
                  "description": "被查看次数"
                },
                "shareCode": {
                  "type": "string",
                  "description": "分享码"
                },
                "createdAt": {
                  "type": "string",
                  "description": "创建时间"
                },
                "expiresAt": {
                  "type": "string",
                  "description": "过期时间"
                }
              }
            }
          },
          "total": {
            "type": "integer",
            "description": "文档总数"
          }
        }
      },
      "_meta": {
        "ui": {
          "componentPath": "components/doc-list-card/doc-list-card"
        }
      }
    },
    {
      "name": "getDocumentInfo",
      "description": "获取指定文档的详细信息，包括标题、类型、字数、访问次数、分享码、有效期等。用于用户查看某篇文档的分享码或确认文档状态。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "shareCode": {
            "type": "string",
            "description": "文档分享码，8 位字母数字。优先使用此参数查询。当用户表达'XX文档的分享码是多少'时，需先从 searchMyDocs 中获取 shareCode"
          },
          "docId": {
            "type": "string",
            "description": "文档数据库 ID。当有 docId 时可用，与 shareCode 二选一"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "description": "文档标题"
          },
          "fileType": {
            "type": "string",
            "description": "文档类型"
          },
          "wordCount": {
            "type": "integer",
            "description": "字数"
          },
          "viewCount": {
            "type": "integer",
            "description": "被查看次数"
          },
          "shareCode": {
            "type": "string",
            "description": "分享码"
          },
          "createdAt": {
            "type": "string",
            "description": "创建时间"
          },
          "expiresAt": {
            "type": "string",
            "description": "过期时间"
          }
        }
      },
      "_meta": {
        "ui": {
          "componentPath": "components/doc-detail-card/doc-detail-card"
        }
      }
    },
    {
      "name": "deleteDocument",
      "description": "删除用户指定的文档。删除前应向用户确认。删除后文档不可恢复，分享码也将失效。",
      "inputSchema": {
        "type": "object",
        "properties": {
          "docId": {
            "type": "string",
            "description": "要删除的文档数据库 ID，必须来自 searchMyDocs 返回的 docId 字段"
          }
        },
        "required": ["docId"]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "deleted": {
            "type": "boolean",
            "description": "是否删除成功"
          }
        }
      }
    }
  ],
  "components": [
    {
      "path": "components/doc-detail-card/doc-detail-card",
      "name": "doc-detail-card",
      "relatedPage": "pages/index/index"
    },
    {
      "path": "components/doc-list-card/doc-list-card",
      "name": "doc-list-card",
      "relatedPage": "pages/index/index"
    }
  ]
}