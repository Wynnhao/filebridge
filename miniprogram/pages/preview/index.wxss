/* pages/preview/index.wxss */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #ffffff;
}

/* ===== 字号档位（CSS 变量驱动） ===== */
/* 注：CSS 变量可穿透组件边界到达 towxml 内部；
   towxml main.wxss 已改为 var() 引用同名变量 */
.page.font-xs {
  --doc-font: 22rpx; --doc-line: 1.9;
  --doc-h1: 30rpx; --doc-h2: 28rpx; --doc-h3: 26rpx;
  --doc-h4: 24rpx; --doc-h5: 22rpx; --doc-h6: 22rpx;
}
.page.font-s {
  --doc-font: 26rpx; --doc-line: 1.8;
  --doc-h1: 36rpx; --doc-h2: 34rpx; --doc-h3: 32rpx;
  --doc-h4: 30rpx; --doc-h5: 28rpx; --doc-h6: 26rpx;
}
.page.font-m {
  --doc-font: 30rpx; --doc-line: 1.7;
  --doc-h1: 42rpx; --doc-h2: 40rpx; --doc-h3: 38rpx;
  --doc-h4: 36rpx; --doc-h5: 34rpx; --doc-h6: 32rpx;
}
.page.font-l {
  --doc-font: 34rpx; --doc-line: 1.6;
  --doc-h1: 48rpx; --doc-h2: 46rpx; --doc-h3: 44rpx;
  --doc-h4: 42rpx; --doc-h5: 40rpx; --doc-h6: 36rpx;
}
.page.font-xl {
  --doc-font: 38rpx; --doc-line: 1.5;
  --doc-h1: 54rpx; --doc-h2: 52rpx; --doc-h3: 48rpx;
  --doc-h4: 46rpx; --doc-h5: 44rpx; --doc-h6: 40rpx;
}

.doc-content {
  font-size: var(--doc-font, 30rpx);
  line-height: var(--doc-line, 1.7);
  padding: 32rpx;
  padding-bottom: 160rpx; /* 给底部操作栏留空间 */
}

/* 带外部样式 HTML 提示 */
.style-warning {
  margin: 16rpx 0 0;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  background: #fffbf0;
  border: 1rpx solid #ffe58f;
  padding: 24rpx 28rpx;
  border-radius: 12rpx;
}

.style-warning-icon {
  font-size: 36rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.style-warning-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #d48806;
  margin-bottom: 6rpx;
}

.style-warning-desc {
  font-size: 22rpx;
  color: #8b6a00;
  line-height: 1.6;
}

/* 元信息栏 */
.doc-meta-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  background: #f8f8f8;
  border-bottom: 1rpx solid #eeeeee;
  flex-shrink: 0;
}

.doc-meta-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.doc-meta-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* Meta 工具按钮（目录 / 字号 / 主题） */
.meta-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.05);
  flex-shrink: 0;
}

.toc-btn { font-size: 32rpx; }

.font-btn-label {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: -2rpx;
}
.font-btn-label-small {
  font-size: 14rpx;
  font-weight: 600;
}

.theme-btn { font-size: 32rpx; }

.doc-type-badge {
  font-size: 18rpx;
  font-weight: 600;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  text-transform: uppercase;
}

.doc-type-badge.md {
  background: #e8f7ef;
  color: #07c160;
}

.doc-type-badge.html {
  background: #fff3e0;
  color: #ff8c00;
}

.doc-type-badge.txt {
  background: #e3f2fd;
  color: #1565c0;
}

.doc-meta-text {
  font-size: 22rpx;
  color: #999999;
}

.doc-expiry {
  font-size: 22rpx;
  color: #ff8c00;
}

/* 文档滚动区 */
.doc-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.doc-scroll {
  flex: 1;
  height: 0;  /* flex 子项需要显式设置才能滚动 */
}

/* 字号滑动条 */
.font-slider-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 32rpx 14rpx;
  background: #f8f8f8;
  border-bottom: 1rpx solid #eeeeee;
}

.font-slider-bar.theme-dark {
  background: #2a2a2a;
  border-bottom-color: #3a3a3a;
}

.font-slider-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #999999;
  flex-shrink: 0;
}

.font-slider-label-lg {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
}

.font-slider-bar.theme-dark .font-slider-label-lg {
  color: #cccccc;
}

.font-slider {
  flex: 1;
}

/* 降级原始文本样式 */
.raw-content {
  font-family: 'Menlo', 'Courier New', monospace;
  font-size: 24rpx;
  line-height: 1.7;
  color: #555555;
  white-space: pre-wrap;
  word-break: break-all;
}

/* towxml 安装提示 */
.towxml-hint {
  margin: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  text-align: center;
}

.hint-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.hint-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.hint-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.hint-code {
  background: #f4f4f4;
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  font-family: monospace;
  font-size: 26rpx;
  color: #333333;
  margin: 8rpx 0 16rpx;
}

/* 错误状态 */
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 70vh;
  padding: 32rpx;
  text-align: center;
}

.error-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.error-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.error-desc {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 32rpx;
}

.btn-retry {
  background: #07c160;
  color: #ffffff;
  border-radius: 48rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  border: none;
}

.btn-retry::after {
  border: none;
}

/* ===== 骨架屏 ===== */
.skeleton-wrap {
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.skeleton-block {
  height: 28rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
}

.skeleton-title { width: 45%; height: 40rpx; }
.skeleton-line  { width: 100%; }
.skeleton-line.short  { width: 70%; }
.skeleton-line.medium { width: 85%; }

@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ===== 目录面板 ===== */
.toc-overlay {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(0, 0, 0, 0.3);
  z-index: 1000;
}

.toc-panel {
  position: absolute;
  top: 0; right: 0;
  width: 62%; height: 100%;
  background: #ffffff;
  box-shadow: -4rpx 0 24rpx rgba(0, 0, 0, 0.1);
  display: flex;
  flex-direction: column;
}

.toc-header {
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  border-bottom: 1rpx solid #eeeeee;
  display: flex;
  justify-content: space-between;
}

.toc-close {
  font-size: 32rpx;
  color: #999999;
  padding: 0 8rpx;
}

.toc-list {
  flex: 1;
  padding: 8rpx 0;
}

.toc-item {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #555555;
  border-left: 4rpx solid transparent;
}

.toc-item.toc-level-1 { font-weight: 600; color: #1a1a1a; padding-left: 28rpx; }
.toc-item.toc-level-2 { padding-left: 48rpx; }
.toc-item.toc-level-3 { padding-left: 68rpx; font-size: 24rpx; color: #888888; }
.toc-item:active { background: #f5f5f5; border-left-color: #07c160; }

.toc-dot {
  width: 8rpx; height: 8rpx;
  border-radius: 50%;
  background: #07c160;
  margin-right: 12rpx;
  flex-shrink: 0;
}
.toc-dot-1 { width: 10rpx; height: 10rpx; }
.toc-dot-2 { width: 8rpx; height: 8rpx; opacity: 0.7; }
.toc-dot-3 { width: 6rpx; height: 6rpx; opacity: 0.5; }

.toc-empty {
  text-align: center;
  padding: 80rpx 0;
  color: #999999;
  font-size: 24rpx;
}

/* ===== 底部操作栏 ===== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #eeeeee;
  display: flex;
  gap: 16rpx;
}

.btn-theme-toggle {
  background: #f5f5f5;
  color: #333333;
  border-radius: 48rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  text-align: center;
  flex-shrink: 0;
  min-width: 120rpx;
}

.btn-theme-toggle::after {
  border: none;
}

.btn-share-card {
  flex: 1;
  background: #07c160;
  color: #ffffff;
  border-radius: 48rpx;
  padding: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  text-align: center;
}

.btn-share-card::after {
  border: none;
}

/* ===== 深色主题 ===== */
.doc-wrap.theme-dark {
  background: #1a1a1a;
}

.doc-wrap.theme-dark .doc-meta-bar.theme-dark {
  background: #2a2a2a;
  border-bottom-color: #3a3a3a;
}

.doc-wrap.theme-dark .meta-btn {
  background: rgba(255, 255, 255, 0.1);
}

.doc-wrap.theme-dark .doc-meta-text {
  color: #aaaaaa;
}

.doc-wrap.theme-dark .doc-expiry {
  color: #ffaa44;
}

.doc-wrap.theme-dark .doc-type-badge.md {
  background: #1a3a2a;
  color: #4ade80;
}

.doc-wrap.theme-dark .doc-type-badge.html {
  background: #3a2a1a;
  color: #ffaa44;
}

.doc-wrap.theme-dark .doc-type-badge.txt {
  background: #1a2a3a;
  color: #60a5fa;
}

.doc-wrap.theme-dark .style-warning {
  background: #2a2510;
  border-color: #5a4a20;
}

.doc-wrap.theme-dark .style-warning-title {
  color: #ffcc44;
}

.doc-wrap.theme-dark .style-warning-desc {
  color: #ccaa44;
}

.doc-wrap.theme-dark .raw-content {
  color: #cccccc;
}

.doc-wrap.theme-dark .skeleton-block {
  background: linear-gradient(90deg, #2a2a2a 25%, #3a3a3a 50%, #2a2a2a 75%);
  background-size: 200% 100%;
}

/* 深色目录面板 */
.toc-panel.theme-dark {
  background: #2a2a2a;
}

.toc-panel.theme-dark .toc-header {
  color: #cccccc;
  border-bottom-color: #3a3a3a;
}

.toc-panel.theme-dark .toc-item {
  color: #aaaaaa;
}

.toc-panel.theme-dark .toc-item.toc-level-1 {
  color: #ffffff;
}

.toc-panel.theme-dark .toc-item:active {
  background: #3a3a3a;
}

.toc-panel.theme-dark .toc-close {
  color: #aaaaaa;
}

/* 深色底部栏 */
.bottom-bar.theme-dark {
  background: #2a2a2a;
  border-top-color: #3a3a3a;
}

.bottom-bar.theme-dark .btn-theme-toggle {
  background: #3a3a3a;
  color: #cccccc;
}

.bottom-bar.theme-dark .btn-share-card {
  background: #07c160;
}
