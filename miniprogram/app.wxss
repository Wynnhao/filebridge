/* app.wxss - 全局样式 */
page {
  background-color: #f8f8f8;
  color: #1a1a1a;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 0 32rpx;
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.theme-dark .card {
  background: #2a2a2a;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.2);
}

/* 主要按钮 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #07c160;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.btn-primary::after {
  border: none;
}

/* 次要按钮 */
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0f0f0;
  color: #333333;
  border-radius: 12rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  border: none;
}

.btn-secondary::after {
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  color: #999999;
}

.empty-state .empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-state .empty-text {
  font-size: 28rpx;
  color: #bbbbbb;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
  flex-direction: column;
  gap: 24rpx;
  color: #999999;
}
